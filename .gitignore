venv/
env/
.venv/
.env/
*_env/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Jupyter Notebook
.ipynb_checkpoints/

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
*.log
logs/

# Testing
.coverage
.pytest_cache/
htmlcov/
.tox/
.nox/

# Local development files
*.local
.env.local

# Note: We DO want to track models/ and metrics/ directories
# as they contain workflow outputs
# But we might want to ignore very large files
# *.joblib  # Uncomment if models get too large
